# TEX browse-use — local engine config. Copy to `.env` and fill in ONE provider.
# `.env` is gitignored; never commit real keys.

# ── LLM provider ──────────────────────────────────────────────────────────
# Pick "anthropic" (simplest for local use — just an API key) or "bedrock".
# If unset, auto-detects: ANTHROPIC_API_KEY present → anthropic, else bedrock.
LLM_PROVIDER=anthropic

# --- Option A: Anthropic API (recommended for local) ---
ANTHROPIC_API_KEY=sk-ant-...
# Computer-use capable model. Default claude-sonnet-4-6. (Fable 5 does NOT support computer use.)
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=4096

# --- Option B: AWS Bedrock (EU / DSGVO) ---
# LLM_PROVIDER=bedrock
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BEDROCK_MODEL=eu.anthropic.claude-sonnet-4-6

# ── Engine ────────────────────────────────────────────────────────────────
PORT=18802
BROWSER_HEADLESS=true
MAX_STEPS=50
SCREENSHOT_WIDTH=1024
SCREENSHOT_HEIGHT=768
# Recent-message context kept per step (lower = fewer tokens/step, helps avoid
# provider rate-limits on long screenshot runs). Default 5.
# SLIDING_WINDOW=5

# ── Data dirs ─────────────────────────────────────────────────────────────
# Runtime data (skills, sessions, vault, downloads…) defaults to ./stack/data,
# derived from the source location — a fresh clone just works, no config needed.
# Override the whole tree with CUA_ROOT, or any single dir below. Do NOT point
# these at a path you can't write to (the engine mkdir's them on first use).
# CUA_ROOT=/abs/path/to/stack
# SKILLS_DIR=
# SESSION_DIR=
# VAULT_DIR=

# Vault encryption key for stored app logins (falls back to AWS secret if unset).
# Set a stable random value if you use the credential vault.
# ENCRYPTION_KEY=

# Optional Postgres audit log. Leave empty to disable (engine still runs).
CU_AUDIT_DATABASE_URL=

# ── MCP client → engine ───────────────────────────────────────────────────
# The browse_use MCP server uses this to reach the engine.
TEX_ENGINE_URL=http://127.0.0.1:18802
